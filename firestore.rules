rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@abada.app';
    }

    // Song overrides and extra songs: anyone can read, only admin can write
    match /song_overrides/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /songs_extra/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User docs: owner can read/write their own
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
